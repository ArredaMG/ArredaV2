            tax: 10,
            in_house: Math.random() > 0.5,
            executed_cost: null,
            receipt_link: null
          });
        }
      });

      await supabase.from('cost_items').insert(itemsToInsert);
    }
    console.log("Mock data injected successfully!");
  } catch (error) {
    console.error("Error injecting mock data:", error);
    throw error;
  }
};

