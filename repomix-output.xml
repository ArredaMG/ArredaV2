import { CostGroup, CostItem, ProjectVersion } from '../types';

/**
 * Calcula o valor de venda baseado no custo e margem (Markup Multiplicador "por fora")
 * Fórmula: Custo * (1 + (Margem / 100))
 */
export function calculateVenda(cost: number, marginPercent: number): number {
  return cost * (1 + (marginPercent / 100));
}

/**
 * Calcula o lucro baseado no custo e margem (Multiplicador Simples)
 * Fórmula: Custo * (Margem / 100)
 */
export function calculateProfit(cost: number, marginPercent: number): number {
  return cost * (marginPercent / 100);
}

