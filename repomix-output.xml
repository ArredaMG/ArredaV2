<file path="src/lib/project-utils.ts">
import { Project } from '../types';

export const calculateFinancials = (project: Project) => {
  const activeVersion = project.versions?.find(v => v.isActive) || project.versions?.[0];
  if (!activeVersion || !activeVersion.groups) {
    return { total: 0, profit$: 0, tax$: 0, profitPercent: 0, taxPercent: 0, title: project.title, client: project.client, dates: project.recordingDates || [] };
  }

  let totalCusto = 0;
  let totalVendaSemImposto = 0;

  activeVersion.groups.forEach(group => {
    if (group.isActive === false) return;
    let groupCost = 0;
    group.items?.forEach(item => {
      // Cálculo: Custo * Qtd * Dias
      groupCost += (Number(item.unitCost) || 0) * (Number(item.quantity) || 1) * (Number(item.days) || 1);
    });
    totalCusto += groupCost;
    
    const margin = group.margin !== undefined ? group.margin : (activeVersion.defaultMargin || 0);
    // Venda do grupo = Custo / (1 - Margem/100)
    totalVendaSemImposto += margin < 100 ? groupCost / (1 - (margin / 100)) : groupCost;
  });

  const taxPercent = activeVersion.defaultTax || 0;
  // Total Final = Venda Sem Imposto / (1 - Imposto/100)
  const totalFinal = taxPercent < 100 ? totalVendaSemImposto / (1 - (taxPercent / 100)) : totalVendaSemImposto;
  
  const taxAmount = totalFinal - totalVendaSemImposto;
  const profitAmount = totalFinal - totalCusto - taxAmount;

  return {
    total: totalFinal,
    profit$: profitAmount,
    tax$: taxAmount,
    profitPercent: activeVersion.defaultMargin || 0,
    taxPercent: taxPercent,
    title: project.title,
    client: project.client,
    dates: project.recordingDates || []
  };
};
</file>

