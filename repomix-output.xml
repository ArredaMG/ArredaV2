      const { error: vErr } = await supabase.from('project_versions').update({
        name: version.name,
        date: version.date,
        default_tax: version.defaultTax / 100,
        default_margin: version.defaultMargin / 100
      }).eq('id', version.id);
      if (vErr) throw vErr;

      const validGroupIds = version.groups.map(g => g.id);
      const validItemIds: string[] = [];
      const groupsToUpsert: any[] = [];
      const itemsToUpsert: any[] = [];

      // 2. Mapeamento de Dados
      version.groups.forEach(g => {
        const groupData: any = {
          id: g.id,
          version_id: version.id,
          name: g.name,
          margin: g.margin !== undefined ? g.margin / 100 : null
        };
        if (hasActiveColumn) groupData.is_active = g.isActive !== false;
        groupsToUpsert.push(groupData);

        g.items.forEach(i => {
          validItemIds.push(i.id);
          itemsToUpsert.push({
            id: i.id,
            group_id: g.id,
            role: i.role,
            name: i.name,
            quantity: i.quantity,
            days: i.days,
            unit_cost: i.unitCost,
            tax: i.tax,
            in_house: i.inHouse,
            executed_cost: i.executedCost,
            receipt_link: i.receiptLink
          });
        });
      });

      // 3. Upsert Seguro: Grupos
      if (groupsToUpsert.length > 0) {
        const { error: gError } = await supabase.from('cost_groups').upsert(groupsToUpsert);
        if (gError) throw gError;
      }

      // 4. Upsert Seguro: Itens
      if (itemsToUpsert.length > 0) {
        const { error: iError } = await supabase.from('cost_items').upsert(itemsToUpsert);
        if (iError) throw iError;
      }

      // 5. Limpeza Inteligente (Orphans Cleanup): Itens
      if (validGroupIds.length > 0) {
        if (validItemIds.length > 0) {
          const { error: delItemsErr } = await supabase
            .from('cost_items')
            .delete()
            .in('group_id', validGroupIds)
            .not('id', 'in', `(${validItemIds.join(',')})`);
          if (delItemsErr) throw delItemsErr;
        } else {
          const { error: delItemsErr } = await supabase
            .from('cost_items')
            .delete()
            .in('group_id', validGroupIds);
          if (delItemsErr) throw delItemsErr;
        }
      }

      // 6. Limpeza Inteligente (Orphans Cleanup): Grupos
      if (validGroupIds.length > 0) {
        const { error: delGroupsErr } = await supabase
          .from('cost_groups')
          .delete()
          .eq('version_id', version.id)
          .not('id', 'in', `(${validGroupIds.join(',')})`);
        if (delGroupsErr) throw delGroupsErr;
      } else {
        const { error: delGroupsErr } = await supabase
          .from('cost_groups')
          .delete()
          .eq('version_id', version.id);
        if (delGroupsErr) throw delGroupsErr;
