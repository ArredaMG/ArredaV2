}

export function getItemMetrics(item: CostItem, groupMargin: number, taxRate: number = 0): ItemMetrics {
  const margin = item.custom_margin ?? item.margin ?? groupMargin;
  const isLogistica = item.category === 'Logistica';
  
  const baseCost = item.unitCost * item.quantity * (item.days || 1);
  const lucro = isLogistica ? 0 : calculateProfit(baseCost, margin);
  const venda = baseCost + lucro;
  
  // Imposto no item (Markup Divisor)
  let totalFinal = venda;
  if (taxRate > 0 && taxRate < 100) {
    totalFinal = venda / (1 - (taxRate / 100));
  }
  
  const valorImposto = totalFinal - venda;

  return {
    baseCost,
    venda,
    lucro,
    valorMargem: lucro,
    valorImposto,
    totalFinal,
    isIH: !!(item.inHouse || item.is_in_house),
    category: item.category || 'Equipe'
  };
}

/**
 * Métricas de uma categoria (grupo)
 */
export interface GroupMetrics {
  totalCusto: number;
  totalVenda: number;
  totalLucro: number;
  totalLucroIH: number;
  custoEquipe: number;
  custoLogistica: number;
  vendaEquipe: number;
  vendaLogistica: number;
  lucroOperacional: number;
  valorImpostos: number;
  totalProposta: number;
}

export function getGroupMetrics(group: CostGroup, defaultMargin: number): GroupMetrics {
  const groupMargin = group.margin !== undefined ? group.margin : defaultMargin;
  
  return group.items.reduce((acc, item) => {
    const metrics = getItemMetrics(item, groupMargin);
    const isLogistica = item.category === 'Logistica';
    
    return {
      totalCusto: acc.totalCusto + metrics.baseCost,
      totalVenda: acc.totalVenda + metrics.venda,
      totalLucro: acc.totalLucro + metrics.lucro,
      totalLucroIH: acc.totalLucroIH + (metrics.isIH ? metrics.lucro : 0),
      custoEquipe: acc.custoEquipe + (isLogistica ? 0 : metrics.baseCost),
      custoLogistica: acc.custoLogistica + (isLogistica ? metrics.baseCost : 0),
      vendaEquipe: acc.vendaEquipe + (isLogistica ? 0 : metrics.venda),
      vendaLogistica: acc.vendaLogistica + (isLogistica ? metrics.venda : 0),
      lucroOperacional: acc.lucroOperacional + metrics.lucro,
      valorImpostos: acc.valorImpostos + metrics.valorImposto,
      totalProposta: acc.totalProposta + metrics.totalFinal
    };
  }, { 
    totalCusto: 0, 
    totalVenda: 0, 
    totalLucro: 0, 
    totalLucroIH: 0,
    custoEquipe: 0,
    custoLogistica: 0,
    vendaEquipe: 0,
    vendaLogistica: 0,
    lucroOperacional: 0,
    valorImpostos: 0,
    totalProposta: 0
  });
}

/**
 * Métricas globais da versão do projeto
 */
export interface VersionTotals {
  totalVenda: number;
  totalCost: number;
  totalProfit: number;
  totalTax: number;
  totalClient: number;
  totalExecuted: number;
  lucroReal: number;
  
  custoEquipe: number;
  custoLogistica: number;
  lucroOperacional: number;
  vendaEquipe: number;
  vendaLogistica: number;
  subtotal: number;
  totalProposta: number;
  valorImpostos: number;
}

export function calculateVersionTotals(version: ProjectVersion): VersionTotals {
  let custoEquipe = 0;
  let custoLogistica = 0;
  let totalExecuted = 0;
  let oldTotalCost = 0;

  version.groups.forEach(group => {
    if (group.isActive === false) return;
    
    group.items.forEach(item => {
      const baseCost = item.unitCost * item.quantity * (item.days || 1);
      const isLogistica = item.category === 'Logistica';
      
      if (isLogistica) {
        custoLogistica += baseCost;
      } else {
        custoEquipe += baseCost;
      }
      
      const isIH = !!(item.inHouse || item.is_in_house);
      oldTotalCost += isIH ? 0 : baseCost;
      totalExecuted += item.executedCost || 0;
    });
  });

  const margem = version.defaultMargin;
  const taxaImposto = version.defaultTax;

  // Fórmulas do Usuário:
  // Lucro Operacional = Custo Equipa * (Margem de Lucro / 100)
  const lucroOperacional = custoEquipe * (margem / 100);
  
  // Venda Equipa = Custo Equipa + Lucro Operacional
  const vendaEquipe = custoEquipe + lucroOperacional;
  
  // Venda Logística = Custo Logística
  const vendaLogistica = custoLogistica;
  
  // Subtotal (Sem Impostos) = Venda Equipa + Venda Logística
  const subtotal = vendaEquipe + vendaLogistica;
  
  // Total da Proposta (Com Impostos) = Subtotal / (1 - (Imposto / 100))
  let totalProposta = subtotal;
  if (taxaImposto > 0 && taxaImposto < 100) {
    totalProposta = subtotal / (1 - (taxaImposto / 100));
  }
  
  // Valor dos Impostos = Total da Proposta - Subtotal
  const valorImpostos = totalProposta - subtotal;

  return {
    custoEquipe,
    custoLogistica,
    lucroOperacional,
    vendaEquipe,
    vendaLogistica,
    subtotal,
    totalProposta,
    valorImpostos,
    
    // Retrocompatibilidade
    totalVenda: subtotal,
    totalCost: oldTotalCost,
    totalProfit: lucroOperacional,
    totalTax: valorImpostos,
    totalClient: totalProposta,
    totalExecuted,
    lucroReal: subtotal - totalExecuted
  };
}

export function calculateProjectTotals(version: ProjectVersion): VersionTotals {
  return calculateVersionTotals(version);
}

