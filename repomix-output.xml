import { CostItem } from '../types';

export interface BudgetTotals {
  subtotal: number;
  taxAmount: number;
  totalFinal: number;
  totalProfit: number;
  itemsWithCalculations: Array<CostItem & { 
    calculatedCost: number; 
    calculatedSaleValue: number; 
    calculatedProfit: number; 
  }>;
}

export function calculateBudgetTotals(
  items: CostItem[], 
  globalMargin: number, 
  globalTax: number
): BudgetTotals {
  let subtotal = 0;
  let totalProfit = 0;

  const itemsWithCalculations = items.map(item => {
    // Valor base do item = quantidade * dias * custo unitário
    const baseValue = item.quantity * (item.days || 1) * item.unitCost;
    
    // Define a margem a ser usada
    const marginToUse = item.custom_margin !== undefined ? item.custom_margin : globalMargin;
    
    let calculatedCost = 0;
    let calculatedSaleValue = 0;
    let calculatedProfit = 0;

    if (item.is_in_house) {
      // IN-HOUSE
      // O custo real é 0, venda é valor base + margem
      calculatedCost = 0;
      calculatedSaleValue = baseValue * (1 + marginToUse / 100);
      calculatedProfit = calculatedSaleValue; // 100% de lucro sobre o valor de venda
    } else {
      // FREELANCER
      // O custo real é o valor base, venda é custo + margem
      calculatedCost = baseValue;
      calculatedSaleValue = baseValue * (1 + marginToUse / 100);
      calculatedProfit = calculatedSaleValue - calculatedCost;
    }

    subtotal += calculatedSaleValue;
    totalProfit += calculatedProfit;

    return {
      ...item,
      calculatedCost,
      calculatedSaleValue,
      calculatedProfit
    };
  });

  const taxAmount = subtotal * (globalTax / 100);
  const totalFinal = subtotal + taxAmount;

  return {
    subtotal,
    taxAmount,
    totalFinal,
    totalProfit,
    itemsWithCalculations
  };
}

