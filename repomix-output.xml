                    }}
                  >
                  <summary className="flex items-center justify-between p-5 bg-zinc-50 dark:bg-zinc-900/50 border-b border-zinc-100 dark:border-zinc-800 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
